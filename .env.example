# Echolot — environment configuration
# Copy to .env (or set in Railway service env vars)

# Optional — defaults shown
# DB_PATH=echolot.db                 # Railway: /data/echolot.db (mount /data volume!)
# SOURCES_PATH=sources.yaml
# SCRAPE_INTERVAL_MINUTES=30
# RETENTION_DAYS=21
# ECHOLOT_CONCURRENCY=20             # parallel fetches
# ECHOLOT_FETCH_TIMEOUT=30
# PORT=8000
