# =============================================================================
# Echolot Domain Intelligence - Environment configuration
# =============================================================================

# --- Data storage ---
DATA_DIR=./data
CACHE_DIR=./data/cache
CACHE_TTL_HOURS=168  # 7 days

# --- Ranking sources (all free + commercial OK) ---

# Tranco list - public, no auth needed for daily list download
TRANCO_ENABLED=true
TRANCO_DAILY_URL=https://tranco-list.eu/top-1m.csv.zip

# Cisco Umbrella - public, no auth, free for commercial use
UMBRELLA_ENABLED=true
UMBRELLA_DAILY_URL=https://s3-us-west-1.amazonaws.com/umbrella-static/top-1m.csv.zip

# Majestic Million - CC BY 3.0 (commercial OK with attribution)
MAJESTIC_ENABLED=true
MAJESTIC_DAILY_URL=https://downloads.majestic.com/majestic_million.csv

# OpenPageRank - free tier 1000 req/day, commercial OK
# Register at: https://www.domcop.com/openpagerank/
OPENPAGERANK_ENABLED=false
OPENPAGERANK_API_KEY=

# --- GeoIP database (MaxMind GeoLite2) ---
# Free with registration: https://www.maxmind.com/en/geolite2/signup
# CC BY-SA 4.0 - commercial OK with attribution
GEOIP_DB_PATH=./data/GeoLite2-Country.mmdb

# --- AI Classification (optional - via Claus-Bridge or SiliconFlow direct) ---
# If empty, falls back to keyword-based classification
AI_CLASSIFIER_ENABLED=true
AI_API_BASE=https://api.siliconflow.cn/v1
AI_API_KEY=
AI_MODEL=moonshotai/Kimi-K2-Instruct

# --- Echolot integration ---
# If you want to lookup domains in your own Echolot corpus first
ECHOLOT_DB_URL=
ECHOLOT_SPHERE_TABLE=spheres

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8080
API_KEY=   # Optional - if set, requires X-API-Key header
